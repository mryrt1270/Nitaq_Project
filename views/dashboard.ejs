<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>لوحة التحكم - Nitaq</title>

<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@400;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/style.css">
</head>

<body>
<style>

    @media (max-width: 768px){

.dash-container{
    padding:120px 12px 50px;
}

.dash-header{
    flex-direction:column;
    align-items:flex-start;
    gap:12px;
    margin-bottom:30px;
}

.dash-header h1{
    font-size:28px;
    line-height:1.4;
}

.dash-header p{
    font-size:14px;
}

.stats-bar{
    flex-direction:column;
    gap:16px;
    padding:18px;
    margin-bottom:30px;
}

.stats-bar div{
    text-align:right;
}

.stats-bar span{
    font-size:20px;
}

.dash-actions{
    flex-direction:column;
    gap:14px;
}

.dash-actions button{
    width:100%;
    min-width:unset;
    padding:18px;
    font-size:15px;
    border-radius:14px;
}

.users-table-wrapper{
    overflow-x:auto;
    -webkit-overflow-scrolling:touch;
}

.users-table th,
.users-table td{
    padding:10px;
    font-size:12px;
}

.rule-item{
    padding:16px;
    border-radius:14px;
}

.admin-form{
    max-width:100%;
}

.admin-form select,
.admin-form input,
.admin-form button{
    width:100%;
}

}

</style>

<video class="video-bg" autoplay muted loop playsinline>
    <source src="/video/background.mp4" type="video/mp4">
</video>

<nav class="navbar">
    <div class="logo">Nitaq</div>

    <div class="nav-links">
        <a href="/">الرئيسية</a>

        <% if (user.role === "founder") { %>
            <a href="/users">إدارة المستخدمين</a>
        <% } %>

        <% if (user.role === "admin" || user.role === "founder") { %>
            <a href="/admin">إدارة القواعد</a>
        <% } %>
    </div>

    <button class="nav-btn" onclick="window.location.href='/logout'">
        تسجيل الخروج
    </button>
</nav>

<section class="dash-container">

    <div class="dash-header">
        <div>
            <h1>مرحباً <%= user.name %></h1>
            <p><%= user.email %></p>
        </div>

        <div class="role-badge">
            <% if (user.role === "founder") { %>
                المؤسس
            <% } else if (user.role === "admin") { %>
                أدمن
            <% } else { %>
                مستخدم
            <% } %>
        </div>
    </div>

    <div class="stats-bar">
        <div>
            <h3>عدد العمليات</h3>
            <span><%= requests ? requests.length : 0 %></span>
        </div>
        <div>
            <h3>الحالة</h3>
            <span class="active-dot">نشط</span>
        </div>
        <div>
            <h3>الدور الحالي</h3>
            <span>
                <% if (user.role === "founder") { %>
                    المؤسس
                <% } else if (user.role === "admin") { %>
                    أدمن
                <% } else { %>
                    مستخدم
                <% } %>
            </span>
        </div>
    </div>

   <div class="dash-actions">

<!-- زر الخدمات لكل المستخدمين -->
<button onclick="window.location.href='/services'">
استكشف الصلاحيات
</button>

<!-- زر السجل -->
<button onclick="window.location.href='/timeline'">
عرض السجل
</button>

<!-- لوحة التحكم فقط لو عنده صلاحية -->
<% if (user.role === "admin" || user.role === "founder") { %>
<button onclick="window.location.href='/admin'">
لوحة التحكم
</button>
<% } %>

</div>

</section>

</body>
</html>