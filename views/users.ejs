<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>إدارة المستخدمين - Nitaq</title>

<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@400;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/style.css">

</head>
<body>

    <style>

        @media (max-width: 768px){

/* الكونتينر */
.dash-container{
    padding:120px 12px 50px;
}

/* العنوان */
.dash-header h1{
    font-size:26px;
}

/* البحث */
.users-search form{
    flex-direction:column;
    gap:10px;
}

.users-search input{
    width:100%;
}

/* الجدول يصير سكرول */
.users-table-wrapper{
    overflow-x:auto;
}

/* تصغير الجدول */
.users-table th,
.users-table td{
    padding:10px;
    font-size:12px;
}

/* الزر */
.main-action-btn{
    font-size:12px;
    padding:6px 10px;
}

/* القائمة */
.actions-menu{
    min-width:200px;
    padding:10px;
}

/* المدخلات */
.action-item input,
.action-item select{
    font-size:12px;
    padding:8px;
}

/* الأزرار */
.action-btn{
    font-size:12px;
    padding:8px;
}

}

    </style>
<video class="video-bg" autoplay muted loop playsinline>
    <source src="/video/background.mp4" type="video/mp4">
</video>

<nav class="navbar">
    <div class="logo">Nitaq</div>

    <div class="nav-links">
        <a href="/dashboard">لوحة التحكم</a>
        <a href="/admin">إدارة القواعد</a>
        <a href="/logs">سجل التعديلات</a>
    </div>

    <button class="nav-btn" onclick="window.location.href='/logout'">
        تسجيل الخروج
    </button>
</nav>

<section class="dash-container">

    <div class="dash-header">
        <div>
            <h1>إدارة المستخدمين</h1>
            <p>التحكم الكامل في الحسابات والصلاحيات</p>
        </div>
    </div>

    <!-- البحث -->
    <div class="users-search">
        <form method="GET" action="/users">
            <input type="text" name="search" placeholder="ابحث بالإيميل..." value="<%= search || '' %>">
            <button class="btn primary">بحث</button>
        </form>
    </div>

    <!-- الجدول -->
    <div class="users-table-wrapper">
        <table class="users-table">

            <thead>
                <tr>
                    <th>الاسم</th>
                    <th>البريد</th>
                    <th>الدور</th>
                    <th>الحالة</th>
                    <th style="text-align:center;">إدارة</th>
                </tr>
            </thead>

            <tbody>

                <% users.forEach(function(u){ %>
                <tr>

                    <!-- الاسم -->
                    <td>
                        <%= u.name %>
                    </td>

                    <!-- الايميل -->
                    <td>
                        <%= u.email %>
                    </td>

                    <!-- الدور -->
                    <td>
                        <span class="role-tag <%= u.role %>">
                            <% if (u.role === "founder") { %>
                                المؤسس
                            <% } else if (u.role === "admin") { %>
                                أدمن
                            <% } else { %>
                                مستخدم
                            <% } %>
                        </span>
                    </td>

                    <!-- الحالة -->
                    <td class="<%= u.banned ? 'status-banned' : 'status-active' %>">
                        <%= u.banned ? "محظور" : "نشط" %>
                    </td>

                    <!-- الإدارة -->
                    <td style="text-align:center;">

                        <% if (u.role !== "founder") { %>

                        <!-- تغيير الاسم -->
                        <form class="inline-form" method="POST" action="/users/change-name">
                            <input type="hidden" name="email" value="<%= u.email %>">
                            <input type="text" name="newName" placeholder="الاسم">
                            <button class="table-btn">حفظ</button>
                        </form>

                        <!-- تغيير الدور -->
                        <form class="inline-form" method="POST" action="/users/role">
                            <input type="hidden" name="email" value="<%= u.email %>">
                            <select name="role">
                                <option value="user" <%= u.role === 'user' ? 'selected' : '' %>>مستخدم</option>
                                <option value="admin" <%= u.role === 'admin' ? 'selected' : '' %>>أدمن</option>
                            </select>
                            <button class="table-btn">تحديث</button>
                        </form>

                        <!-- حظر -->
                        <form class="inline-form" method="POST" action="/users/ban">
                            <input type="hidden" name="email" value="<%= u.email %>">
                            <button class="table-btn danger-btn">حظر</button>
                        </form>

                        <!-- حذف -->
                        <form class="inline-form" method="POST" action="/users/delete" onsubmit="return confirm('متأكد من الحذف؟');">
                            <input type="hidden" name="email" value="<%= u.email %>">
                            <button class="table-btn danger-btn">حذف</button>
                        </form>

                        <% } else { %>
                            <span style="color: gold; font-weight: bold;">
                                المؤسس
                            </span>
                        <% } %>

                    </td>

                </tr>
                <% }) %>

            </tbody>

        </table>
    </div>

</section>

</body>
</html>