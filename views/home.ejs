<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nitaq | لوحتي</title>

<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@400;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/style.css">

<style>
    .video-bg{
    position: fixed;
    top:0;
    left:0;
    width:100%;
    height:100%;
    object-fit: cover;
    z-index: -1; /* هذا أهم سطر 🔥 */
}

.home-container{
    padding:140px 40px 80px;
    max-width:1100px;
    margin:auto;
    position:relative;
    z-index:2;
}

.welcome-box{ margin-bottom:50px; }
.welcome-box h1{ font-size:40px; margin-bottom:15px; }
.welcome-box p{ opacity:.7; }

.quick-actions{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:25px;
    margin-bottom:60px;
}

.action-card{
    display:block;
    text-decoration:none;
    color:white;
    background:rgba(255,255,255,0.05);
    backdrop-filter:blur(25px);
    border-radius:25px;
    padding:35px;
    border:1px solid rgba(255,255,255,0.1);
    transition:.3s;
}

.action-card:hover{
    transform:translateY(-6px);
    box-shadow:0 0 30px rgba(255,255,255,0.2);
}

.action-card h3{ margin-bottom:10px; }
.action-card p{ font-size:14px; opacity:.7; }

.stats-box{
    display:flex;
    gap:30px;
    margin-bottom:60px;
}

.hero-stat{
    background:rgba(255,255,255,0.05);
    padding:25px;
    border-radius:20px;
    border:1px solid rgba(255,255,255,0.08);
}

.hero-stat strong{
    font-size:28px;
    display:block;
}

.hero-stat span{
    font-size:13px;
    opacity:.6;
}

@media (max-width: 768px){
    .home-container{ padding:120px 16px 50px; }
    .welcome-box h1{ font-size:28px; }
    .welcome-box p{ font-size:14px; }
    .quick-actions{ grid-template-columns:1fr; gap:15px; }
    .action-card{ padding:20px; border-radius:18px; }
    .action-card h3{ font-size:16px; }
    .action-card p{ font-size:13px; }
    .stats-box{ flex-direction:column; gap:12px; }
    .hero-stat{ padding:16px; text-align:center; }
    .hero-stat strong{ font-size:22px; }
}
</style>
</head>

<body>

<video class="video-bg" autoplay muted loop playsinline>
<source src="/video/background.mp4" type="video/mp4">
</video>

<nav class="navbar">
    <div class="logo">Nitaq</div>

    <div class="nav-links">
        <a href="/">الرئيسية</a>
        <a href="/profile">ملفي الشخصي</a>
        <a href="/services">التحقق</a>
        <a href="/timeline">السجل</a>
        <% if(user.role === "admin" || user.role === "founder"){ %>
            <a href="/dashboard">لوحة التحكم</a>
        <% } %>
    </div>

    <button class="nav-btn" onclick="window.location.href='/logout'">تسجيل الخروج</button>
</nav>

<section class="home-container">
    <div class="welcome-box">
        <h1>مرحبًا <%= user.name %> 👋</h1>
        <p>ابدأ باستخدام منصة نطاق لإدارة والتحقق من الطلبات النظامية بكل سهولة.</p>
    </div>

    <div class="quick-actions">
        <a href="/services" class="action-card">
            <h3>🔎 بدء التحقق</h3>
            <p>تحقق من مشروعية طلب جهة معينة فورًا.</p>
        </a>

        <a href="/timeline" class="action-card">
            <h3>📜 السجل</h3>
            <p>عرض جميع عمليات التحقق السابقة.</p>
        </a>

        <% if(user.role === "admin" || user.role === "founder"){ %>
        <a href="/dashboard" class="action-card">
            <h3>🛠 لوحة التحكم</h3>
            <p>إدارة القواعد والمستخدمين.</p>
        </a>
        <% } %>
    </div>

    <div class="stats-box">
        <div class="hero-stat">
            <strong><%= totalRequests %></strong>
            <span>عمليات التحقق الخاصة بك</span>
        </div>

        <div class="hero-stat">
            <strong><%= rejectionRate %>%</strong>
            <span>نسبة الطلبات غير المتوافقة</span>
        </div>


        <div class="hero-stat">
            <strong><%= user.role === "founder" ? "المؤسس" : user.role === "admin" ? "أدمن" : "مستخدم" %></strong>
            <span>نوع الحساب</span>
        </div>
    </div>
</section>


<div class="natiq-chat" id="natiqChat">

  <div class="chat-header">
    <span>ناطق 🤖</span>
    <span class="chat-close" onclick="toggleChat()">✖</span>
  </div>

  <div class="chat-body" id="chatDisplay">
    <div class="bot">👋 هلا! أنا ناطق، كيف أساعدك؟</div>
  </div>

  <div class="chat-input-area">
    <input id="chatInput" placeholder="اكتب سؤالك..." />
    <button onclick="sendMessage()">➤</button>
  </div>

</div>

<div class="chat-btn" onclick="toggleChat()">🤖</div>

<div class="natiq-reminder" id="natiqReminder">
  <span>🤖</span>
  <div>
    في حال احتجت للمساعدة، لا تتردد في التواصل مع ناطق.
  </div>
</div>

<style>
.natiq-chat{
    position:fixed;
    bottom:100px;
    right:25px;
    width:320px;
    height:420px;
    background:rgba(20,20,20,0.95);
    backdrop-filter:blur(20px);
    border-radius:18px;
    display:flex;
    flex-direction:column;
    opacity:0;
    transform:translateY(20px) scale(.98);
    pointer-events:none;
    transition:.3s ease;
    z-index:99999;
    border:1px solid rgba(255,255,255,0.08);
    box-shadow:0 20px 50px rgba(0,0,0,.45);
}

.natiq-chat.active{
    opacity:1;
    transform:translateY(0) scale(1);
    pointer-events:auto;
}

.chat-header{
    padding:12px 14px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    border-bottom:1px solid rgba(255,255,255,0.08);
    font-weight:600;
    color:#fff;
}

.chat-close{
    cursor:pointer;
    opacity:.65;
    transition:.2s;
}

.chat-close:hover{
    opacity:1;
}

.chat-body{
    flex:1;
    padding:12px;
    overflow-y:auto;
    display:flex;
    flex-direction:column;
    gap:8px;
    font-size:14px;
    color:#fff;
}

.chat-body .user{
    align-self:flex-end;
    background:#ffffff;
    color:#000;
    padding:8px 12px;
    border-radius:14px 14px 4px 14px;
    max-width:80%;
    line-height:1.6;
}

.chat-body .bot{
    align-self:flex-start;
    background:#2a2a2a;
    color:#fff;
    padding:8px 12px;
    border-radius:14px 14px 14px 4px;
    max-width:80%;
    line-height:1.6;
}

.chat-body .typing{
    align-self:flex-start;
    background:#2a2a2a;
    color:#bfbfbf;
    padding:8px 12px;
    border-radius:14px 14px 14px 4px;
    max-width:80%;
    line-height:1.6;
    font-size:13px;
    animation:pulseTyping 1s infinite ease-in-out;
}

@keyframes pulseTyping{
    0%{ opacity:.45; }
    50%{ opacity:1; }
    100%{ opacity:.45; }
}

.chat-input-area{
    display:flex;
    border-top:1px solid rgba(255,255,255,0.08);
}

.chat-input-area input{
    flex:1;
    padding:12px;
    background:transparent;
    border:none;
    color:#fff;
    outline:none;
    font-family:'IBM Plex Sans Arabic', sans-serif;
}

.chat-input-area input::placeholder{
    color:rgba(255,255,255,.45);
}

.chat-input-area button{
    padding:12px 14px;
    background:#fff;
    color:#000;
    border:none;
    cursor:pointer;
    font-weight:700;
}

.chat-btn{
    position:fixed;
    bottom:25px;
    right:25px;
    width:60px;
    height:60px;
    border-radius:50%;
    background:#fff;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:24px;
    cursor:pointer;
    z-index:99999;
    box-shadow:0 0 25px rgba(255,255,255,0.45);
    transition:.25s ease;
}

.natiq-reminder{
    position:fixed;
    bottom:100px;
    right:100px;
    max-width:280px;
    display:flex;
    align-items:flex-start;
    gap:10px;
    background:rgba(20,20,20,0.95);
    color:#fff;
    border:1px solid rgba(255,255,255,0.08);
    border-radius:16px;
    padding:12px 14px;
    z-index:99998;
    box-shadow:0 20px 50px rgba(0,0,0,.35);
    opacity:0;
    transform:translateY(14px);
    pointer-events:none;
    transition:.35s ease;
    font-size:13px;
    line-height:1.7;
}

.natiq-reminder.show{
    opacity:1;
    transform:translateY(0);
    pointer-events:auto;
}

@media (max-width: 768px){
    .natiq-chat{
        right:14px;
        left:14px;
        width:auto;
        bottom:90px;
        height:420px;
    }

    .natiq-reminder{
        right:14px;
        left:14px;
        bottom:86px;
        max-width:none;
    }
}
</style>

<script>
function toggleChat(){
    document.getElementById('natiqChat').classList.toggle('active');
}

function appendMessage(type, text){
    const chat = document.getElementById('chatDisplay');
    chat.innerHTML += `<div class="${type}">${text}</div>`;
    chat.scrollTop = chat.scrollHeight;
}

function showTyping(){
    const chat = document.getElementById('chatDisplay');
    const typingId = 'typing-indicator';
    const old = document.getElementById(typingId);
    if(old) old.remove();

    const div = document.createElement('div');
    div.className = 'typing';
    div.id = typingId;
    div.textContent = 'ناطق قاعد يكتب...';
    chat.appendChild(div);
    chat.scrollTop = chat.scrollHeight;
}

function hideTyping(){
    const old = document.getElementById('typing-indicator');
    if(old) old.remove();
}

async function sendMessage(){
    const input = document.getElementById('chatInput');
    const text = input.value.trim();
    if(!text) return;

    appendMessage('user', text);
    input.value = '';

    showTyping();

    try{
        const res = await fetch('/api/chat',{
            method:'POST',
            headers:{ 'Content-Type':'application/json' },
            body: JSON.stringify({ message:text })
        });

        const data = await res.json();

        hideTyping();
        appendMessage('bot', data.reply);

        if(data.actions){
            const chat = document.getElementById('chatDisplay');
            chat.innerHTML += `
                <div class="bot" id="rule-actions-box">
                    <div style="display:flex; gap:8px; margin-top:6px;">
                        <button onclick="approveRule()" style="padding:8px 12px;border:none;border-radius:10px;cursor:pointer;">✅ إضافة</button>
                        <button onclick="cancelRule()" style="padding:8px 12px;border:none;border-radius:10px;cursor:pointer;">❌ إلغاء</button>
                    </div>
                </div>
            `;
            chat.scrollTop = chat.scrollHeight;
        }
    }catch(err){
        hideTyping();
        appendMessage('bot', 'صار خطأ 😅');
    }
}

async function approveRule(){
    const res = await fetch('/api/rule-action',{
        method:'POST',
        headers:{ 'Content-Type':'application/json' },
        body: JSON.stringify({ action:'approve' })
    });

    const data = await res.json();
    appendMessage('bot', data.reply);

    const box = document.getElementById('rule-actions-box');
    if(box) box.remove();
}

async function cancelRule(){
    const res = await fetch('/api/rule-action',{
        method:'POST',
        headers:{ 'Content-Type':'application/json' },
        body: JSON.stringify({ action:'cancel' })
    });

    const data = await res.json();
    appendMessage('bot', data.reply);

    const box = document.getElementById('rule-actions-box');
    if(box) box.remove();
}

function showReminder(){
    const reminder = document.getElementById('natiqReminder');
    reminder.classList.add('show');

    setTimeout(() => {
        reminder.classList.remove('show');
    }, 6000);
}

// أول تذكير بعد 8 ثواني
setTimeout(showReminder, 8000);

// كل 15 دقيقة
setInterval(showReminder, 15 * 60 * 1000);

// إرسال بالإنتر
document.addEventListener('DOMContentLoaded', () => {
    const input = document.getElementById('chatInput');
    if(input){
        input.addEventListener('keydown', function(e){
            if(e.key === 'Enter'){
                sendMessage();
            }
        });
    }
});
</script>

</body>
</html>