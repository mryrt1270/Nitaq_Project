<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nitaq | لوحتي</title>

<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@400;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/style.css">

<style>
    .video-bg{
    position: fixed;
    top:0;
    left:0;
    width:100%;
    height:100%;
    object-fit: cover;
    z-index: -1; /* هذا أهم سطر 🔥 */
}

.home-container{
    padding:140px 40px 80px;
    max-width:1100px;
    margin:auto;
    position:relative;
    z-index:2;
}

.welcome-box{ margin-bottom:50px; }
.welcome-box h1{ font-size:40px; margin-bottom:15px; }
.welcome-box p{ opacity:.7; }

.quick-actions{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:25px;
    margin-bottom:60px;
}

.action-card{
    display:block;
    text-decoration:none;
    color:white;
    background:rgba(255,255,255,0.05);
    backdrop-filter:blur(25px);
    border-radius:25px;
    padding:35px;
    border:1px solid rgba(255,255,255,0.1);
    transition:.3s;
}

.action-card:hover{
    transform:translateY(-6px);
    box-shadow:0 0 30px rgba(255,255,255,0.2);
}

.action-card h3{ margin-bottom:10px; }
.action-card p{ font-size:14px; opacity:.7; }

.stats-box{
    display:flex;
    gap:30px;
    margin-bottom:60px;
}

.hero-stat{
    background:rgba(255,255,255,0.05);
    padding:25px;
    border-radius:20px;
    border:1px solid rgba(255,255,255,0.08);
}

.hero-stat strong{
    font-size:28px;
    display:block;
}

.hero-stat span{
    font-size:13px;
    opacity:.6;
}

@media (max-width: 768px){
    .home-container{ padding:120px 16px 50px; }
    .welcome-box h1{ font-size:28px; }
    .welcome-box p{ font-size:14px; }
    .quick-actions{ grid-template-columns:1fr; gap:15px; }
    .action-card{ padding:20px; border-radius:18px; }
    .action-card h3{ font-size:16px; }
    .action-card p{ font-size:13px; }
    .stats-box{ flex-direction:column; gap:12px; }
    .hero-stat{ padding:16px; text-align:center; }
    .hero-stat strong{ font-size:22px; }
}
</style>
</head>

<body>

<video class="video-bg" autoplay muted loop playsinline>
<source src="/video/background.mp4" type="video/mp4">
</video>

<nav class="navbar">
    <div class="logo">Nitaq</div>

    <div class="nav-links">
        <a href="/">الرئيسية</a>
        <a href="/profile">ملفي الشخصي</a>
        <a href="/services">التحقق</a>
        <a href="/timeline">السجل</a>
        <% if(user.role === "admin" || user.role === "founder"){ %>
            <a href="/dashboard">لوحة التحكم</a>
        <% } %>
    </div>

    <button class="nav-btn" onclick="window.location.href='/logout'">تسجيل الخروج</button>
</nav>

<section class="home-container">
    <div class="welcome-box">
        <h1>مرحبًا <%= user.name %> 👋</h1>
        <p>ابدأ باستخدام منصة نطاق لإدارة والتحقق من الطلبات النظامية بكل سهولة.</p>
    </div>

    <div class="quick-actions">
        <a href="/services" class="action-card">
            <h3>🔎 بدء التحقق</h3>
            <p>تحقق من مشروعية طلب جهة معينة فورًا.</p>
        </a>

        <a href="/timeline" class="action-card">
            <h3>📜 السجل</h3>
            <p>عرض جميع عمليات التحقق السابقة.</p>
        </a>

        <% if(user.role === "admin" || user.role === "founder"){ %>
        <a href="/dashboard" class="action-card">
            <h3>🛠 لوحة التحكم</h3>
            <p>إدارة القواعد والمستخدمين.</p>
        </a>
        <% } %>
    </div>

    <div class="stats-box">
        <div class="hero-stat">
            <strong><%= totalRequests %></strong>
            <span>عمليات التحقق الخاصة بك</span>
        </div>

        <div class="hero-stat">
            <strong><%= rejectionRate %>%</strong>
            <span>نسبة الطلبات غير المتوافقة</span>
        </div>


        <div class="hero-stat">
            <strong><%= user.role === "founder" ? "المؤسس" : user.role === "admin" ? "أدمن" : "مستخدم" %></strong>
            <span>نوع الحساب</span>
        </div>
    </div>
</section>

<div class="chat-btn" onclick="toggleChat()">💬</div>

<div class="chat-box" id="chatBox">
    <div class="chat-header">ناطق 🤖</div>

    <div id="chatMessages" class="chat-messages"></div>

    <div class="chat-input">
        <input id="chatInput" placeholder="اكتب سؤالك..." />
        <button onclick="sendMessage()">➤</button>
    </div>
</div>

<style>
.chat-btn{
    position:fixed;
    bottom:20px;
    left:20px;
    background:white;
    color:black;
    padding:14px;
    border-radius:50%;
    cursor:pointer;
    z-index:99999; /* مهم جدًا */
    box-shadow:0 0 15px rgba(0,0,0,0.5);
}

.chat-box{
    position:fixed;
    bottom:100px;
    right:25px;
    width:320px;
    height:450px;
    background:rgba(0,0,0,0.6);
    backdrop-filter:blur(25px);
    border-radius:20px;
    display:flex;

    opacity:0; /* مخفي */
    transform:translateY(30px); /* تحت شوي */
    pointer-events:none;

    transition: all 0.3s ease;

    z-index:99999;
}

.chat-box.active{
    opacity:1;
    transform:translateY(0);
    pointer-events:auto;
}

.chat-header{
    padding:10px;
    background:#222;
}

.chat-messages{
    flex:1;
    padding:10px;
    overflow:auto;
}

.chat-input{
    display:flex;
}

.chat-input input{
    flex:1;
    padding:10px;
}

.chat-input button{
    padding:10px;
}

.chat-btn{
    right:20px;
    left:auto;
}

</style>

<script>

function toggleChat(){
    const box = document.getElementById('chatBox');
    box.classList.toggle('active');
}

async function sendMessage(){

    const input = document.getElementById('chatInput');
    const messages = document.getElementById('chatMessages');

    const text = input.value.trim();
    if(!text) return;

    messages.innerHTML += `<div>👤 ${text}</div>`;
    input.value = "";

    const res = await fetch('/api/chat',{
        method:"POST",
        headers:{ "Content-Type":"application/json" },
        body: JSON.stringify({ message:text })
    });

    const data = await res.json();

    messages.innerHTML += `<div>🤖 ${data.reply}</div>`;

    // 🔥 أزرار الأدمن
    if(data.actions){
        messages.innerHTML += `
            <div style="margin-top:10px;">
                <button onclick="approveRule()">✅ إضافة</button>
                <button onclick="cancelRule()">❌ إلغاء</button>
            </div>
        `;
    }

    messages.scrollTop = messages.scrollHeight;
}

async function approveRule(){

    const messages = document.getElementById('chatMessages');

    const res = await fetch('/api/rule-action',{
        method:"POST",
        headers:{ "Content-Type":"application/json" },
        body: JSON.stringify({ action:"approve" })
    });

    const data = await res.json();

    messages.innerHTML += `<div>🤖 ${data.reply}</div>`;
}

async function cancelRule(){

    const messages = document.getElementById('chatMessages');

    const res = await fetch('/api/rule-action',{
        method:"POST",
        headers:{ "Content-Type":"application/json" },
        body: JSON.stringify({ action:"cancel" })
    });

    const data = await res.json();

    messages.innerHTML += `<div>🤖 ${data.reply}</div>`;
}

</script>

</body>
</html>