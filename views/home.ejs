<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nitaq | لوحتي</title>

<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@400;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/style.css">

<style>
    .video-bg{
    position: fixed;
    top:0;
    left:0;
    width:100%;
    height:100%;
    object-fit: cover;
    z-index: -1; /* هذا أهم سطر 🔥 */
}

.home-container{
    padding:140px 40px 80px;
    max-width:1100px;
    margin:auto;
    position:relative;
    z-index:2;
}

.welcome-box{ margin-bottom:50px; }
.welcome-box h1{ font-size:40px; margin-bottom:15px; }
.welcome-box p{ opacity:.7; }

.quick-actions{
    display:grid;
    grid-template-columns:repeat(auto-fit,minmax(250px,1fr));
    gap:25px;
    margin-bottom:60px;
}

.action-card{
    display:block;
    text-decoration:none;
    color:white;
    background:rgba(255,255,255,0.05);
    backdrop-filter:blur(25px);
    border-radius:25px;
    padding:35px;
    border:1px solid rgba(255,255,255,0.1);
    transition:.3s;
}

.action-card:hover{
    transform:translateY(-6px);
    box-shadow:0 0 30px rgba(255,255,255,0.2);
}

.action-card h3{ margin-bottom:10px; }
.action-card p{ font-size:14px; opacity:.7; }

.stats-box{
    display:flex;
    gap:30px;
    margin-bottom:60px;
}

.hero-stat{
    background:rgba(255,255,255,0.05);
    padding:25px;
    border-radius:20px;
    border:1px solid rgba(255,255,255,0.08);
}

.hero-stat strong{
    font-size:28px;
    display:block;
}

.hero-stat span{
    font-size:13px;
    opacity:.6;
}

@media (max-width: 768px){
    .home-container{ padding:120px 16px 50px; }
    .welcome-box h1{ font-size:28px; }
    .welcome-box p{ font-size:14px; }
    .quick-actions{ grid-template-columns:1fr; gap:15px; }
    .action-card{ padding:20px; border-radius:18px; }
    .action-card h3{ font-size:16px; }
    .action-card p{ font-size:13px; }
    .stats-box{ flex-direction:column; gap:12px; }
    .hero-stat{ padding:16px; text-align:center; }
    .hero-stat strong{ font-size:22px; }
}
</style>
</head>

<body>

<video class="video-bg" autoplay muted loop playsinline>
<source src="/video/background.mp4" type="video/mp4">
</video>

<nav class="navbar">
    <div class="logo">Nitaq</div>

    <div class="nav-links">
        <a href="/">الرئيسية</a>
        <a href="/profile">ملفي الشخصي</a>
        <a href="/services">التحقق</a>
        <a href="/timeline">السجل</a>
        <a href="https://twitter.com/nita_q11
" target="_blank" class="contact-btn">
  تواصل معنا
</a>
        <% if(user.role === "admin" || user.role === "founder"){ %>
            <a href="/dashboard">لوحة التحكم</a>
        <% } %>
    </div>

    <button class="nav-btn" onclick="window.location.href='/logout'">تسجيل الخروج</button>
</nav>

<section class="home-container">
    <div class="welcome-box">
        <h1>مرحبًا <%= user.name %> 👋</h1>
        <p>ابدأ باستخدام منصة نطاق لإدارة والتحقق من الطلبات النظامية بكل سهولة.</p>
    </div>

    <div class="quick-actions">
        <a href="/services" class="action-card">
            <h3>🔎 بدء التحقق</h3>
            <p>تحقق من مشروعية طلب جهة معينة فورًا.</p>
        </a>

        <a href="/timeline" class="action-card">
            <h3>📜 السجل</h3>
            <p>عرض جميع عمليات التحقق السابقة.</p>
        </a>

        <% if(user.role === "admin" || user.role === "founder"){ %>
        <a href="/dashboard" class="action-card">
            <h3>🛠 لوحة التحكم</h3>
            <p>إدارة القواعد والمستخدمين.</p>
        </a>
        <% } %>
    </div>

    <div class="stats-box">
        <div class="hero-stat">
            <strong><%= totalRequests %></strong>
            <span>عمليات التحقق الخاصة بك</span>
        </div>

        <div class="hero-stat">
            <strong><%= rejectionRate %>%</strong>
            <span>نسبة الطلبات غير المتوافقة</span>
        </div>


        <div class="hero-stat">
            <strong><%= user.role === "founder" ? "المؤسس" : user.role === "admin" ? "أدمن" : "مستخدم" %></strong>
            <span>نوع الحساب</span>
        </div>
    </div>
</section>


<style>

.chat-header{
    padding:12px 14px;
    display:flex;
    justify-content:space-between;
    align-items:center;
    border-bottom:1px solid rgba(255,255,255,0.08);
    font-weight:600;
    color:#fff;
}

.chat-close{
    cursor:pointer;
    opacity:.65;
    transition:.2s;
}

.chat-close:hover{
    opacity:1;
}

.chat-body{
    flex:1;
    padding:12px;
    overflow-y:auto;
    display:flex;
    flex-direction:column;
    gap:8px;
    font-size:14px;
    color:#fff;
}

.chat-body .user{
    align-self:flex-end;
    background:#ffffff;
    color:#000;
    padding:8px 12px;
    border-radius:14px 14px 4px 14px;
    max-width:80%;
    line-height:1.6;
}

.chat-body .bot{
    align-self:flex-start;
    background:#2a2a2a;
    color:#fff;
    padding:8px 12px;
    border-radius:14px 14px 14px 4px;
    max-width:80%;
    line-height:1.6;
}

.chat-body .typing{
    align-self:flex-start;
    background:#2a2a2a;
    color:#bfbfbf;
    padding:8px 12px;
    border-radius:14px 14px 14px 4px;
    max-width:80%;
    line-height:1.6;
    font-size:13px;
    animation:pulseTyping 1s infinite ease-in-out;
}

@keyframes pulseTyping{
    0%{ opacity:.45; }
    50%{ opacity:1; }
    100%{ opacity:.45; }
}

.chat-input-area{
    display:flex;
    border-top:1px solid rgba(255,255,255,0.08);
}

.chat-input-area input{
    flex:1;
    padding:12px;
    background:transparent;
    border:none;
    color:#fff;
    outline:none;
    font-family:'IBM Plex Sans Arabic', sans-serif;
}

.chat-input-area input::placeholder{
    color:rgba(255,255,255,.45);
}

.chat-input-area button{
    padding:12px 14px;
    background:#fff;
    color:#000;
    border:none;
    cursor:pointer;
    font-weight:700;
}

.chat-btn{
    position:fixed;
    bottom:25px;
    right:25px;
    width:60px;
    height:60px;
    border-radius:50%;
    background:#fff;
    display:flex;
    align-items:center;
    justify-content:center;
    font-size:24px;
    cursor:pointer;
    z-index:99999;
    box-shadow:0 0 25px rgba(255,255,255,0.45);
    transition:.25s ease;
}

</style>



</body>
</html>