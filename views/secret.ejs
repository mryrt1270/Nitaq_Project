<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<title>نتيجة التحقق - Nitaq</title>

<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@400;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/style.css">

<style>
.result-wrapper {
    min-height: 100vh;
    padding: 120px 20px;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    z-index: 2;
}

.result-card {
    width: 600px;              /* أصغر */
    max-width: 90%;            /* متجاوب */
    background: rgba(255,255,255,0.05);
    backdrop-filter: blur(35px);
    border-radius: 30px;
    padding: 45px;             /* تقليل الحشو */
    border: 1px solid rgba(255,255,255,0.1);
    box-shadow: 0 30px 80px rgba(0,0,0,0.6);
    text-align: center;
}

.glow-circle {
    width: 130px;
    height: 130px;
    border-radius: 50%;
    margin: 0 auto 30px auto;

    display: flex;
    align-items: center;
    justify-content: center;

    font-size: 42px;
    font-weight: 700;

    position: relative;

    backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.15);
}

.glow-circle {
    width: 140px;
    height: 140px;
    border-radius: 50%;
    margin: 0 auto 35px auto;

    display: flex;
    align-items: center;
    justify-content: center;

    font-size: 48px;
    font-weight: 700;

    position: relative;
    backdrop-filter: blur(25px);

    background: rgba(255,255,255,0.05);
    border: 1px solid rgba(255,255,255,0.15);

    animation: pulseSoft 2.5s ease-in-out infinite;
}

/* الطبقة الداخلية اللامعة */
.glow-circle::after {
    content: "";
    position: absolute;
    inset: 10px;
    border-radius: 50%;
    background: radial-gradient(circle at 30% 30%, rgba(255,255,255,0.25), transparent 60%);
    opacity: 0.5;
}

.glow-circle {
    width: 130px;
    height: 130px;
    border-radius: 50%;
    margin: 0 auto 30px auto;

    display: flex;
    align-items: center;
    justify-content: center;

    font-size: 42px;
    font-weight: 700;

    position: relative;

    backdrop-filter: blur(20px);
    border: 1px solid rgba(255,255,255,0.15);
}

/* خلفية التوهج */
.glow-circle::before {
    content: "";
    position: absolute;
    inset: -25px;
    border-radius: 50%;
    z-index: -1;
    filter: blur(40px);
}

.allowed-style {
    color: #22c55e;
}

.allowed-style::before {
    background: radial-gradient(circle, rgba(34,197,94,0.6), transparent 70%);
}

.denied-style {
    color: #ef4444;
}

.denied-style::before {
    background: radial-gradient(circle, rgba(239,68,68,0.6), transparent 70%);
}

.status-title {
    font-size: 26px;
    font-weight: 700;
    margin-bottom: 35px;
}

.info-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 20px;
    margin-bottom: 30px;
    text-align: right;
}

.info-box {
    background: rgba(255,255,255,0.05);
    padding: 18px;
    border-radius: 15px;
    border: 1px solid rgba(255,255,255,0.08);
}

.info-box span {
    display: block;
    opacity: 0.6;
    font-size: 13px;
    margin-bottom: 6px;
}

.info-box strong {
    font-size: 15px;
}

.reason-box {
    margin-top: 25px;
    padding: 25px;
    border-radius: 18px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.1);
    text-align: right;
}

.law-ref {
    margin-top: 12px;
    font-size: 14px;
    opacity: 0.75;
}

.verify-id {
    margin-top: 25px;
    font-size: 12px;
    opacity: 0.5;
}

.back-btn {
    margin-top: 35px;
    padding: 14px 30px;
    border-radius: 30px;
    border: 1px solid rgba(255,255,255,0.2);
    background: rgba(255,255,255,0.05);
    color: white;
    cursor: pointer;
    transition: 0.3s;
}

.back-btn:hover {
    background: rgba(255,255,255,0.15);
}

.confidence-box{
    margin-top:20px;
    padding:15px;
    border-radius:15px;
    background:rgba(255,255,255,0.05);
    border:1px solid rgba(255,255,255,0.1);
}

</style>
</head>
<body>

<video class="video-bg" autoplay muted loop playsinline>
    <source src="/video/background.mp4" type="video/mp4">
</video>

<section class="result-wrapper">
<div class="result-card">

<div class="glow-circle <%= allowed ? 'allowed-style' : 'denied-style' %>">
    <%= allowed ? '✓' : '✕' %>
</div>

<div class="status-title">
<%= allowed ? "الطلب متوافق مع الأنظمة" : "الطلب غير متوافق مع الأنظمة" %>
</div>

<div class="info-grid">
    <div class="info-box">
        <span>القطاع</span>
        <strong><%= sector %></strong>
    </div>

    <div class="info-box">
        <span>الجهة</span>
        <strong><%= entity %></strong>
    </div>

    <div class="info-box">
        <span>المستند المطلوب</span>
        <strong><%= data %></strong>
    </div>

    <div class="info-box">
        <span>وقت التحقق</span>
        <strong><%= time %></strong>
    </div>
</div>

<div class="reason-box">
<strong>سبب القرار:</strong>
<p><%= reason %></p>

<div class="confidence-box">
<strong>مستوى الثقة:</strong>
<%= allowed ? "مرتفع" : "منخفض" %>
</div>

<% if(typeof lawReference !== "undefined" && lawReference){ %>
<div class="law-ref">
مرجع نظامي: <%= lawReference %><br>
<%= description %>
</div>
<% } %>
</div>

<div class="verify-id">
رقم التحقق: <%= verificationId %>
</div>


<button class="back-btn" onclick="window.location.href='/services'">
العودة للتحقق
</button>


</div>
</section>

</body>
</html>