<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>سجل العمليات - Nitaq</title>

<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@400;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/style.css">
</head>

<body>
<style>

    @media (max-width: 768px){

.dash-container{
    padding:120px 16px 50px;
}

.dash-header{
    flex-direction:column;
    align-items:flex-start;
    gap:10px;
    margin-bottom:25px;
}

.dash-header h1{
    font-size:26px;
}

.users-table-wrapper{
    overflow-x:auto;
    -webkit-overflow-scrolling:touch;
    border-radius:16px;
}

.users-table th,
.users-table td{
    padding:10px;
    font-size:12px;
    white-space: nowrap;
}

.log-action{
    font-size:12px;
    padding:5px 10px;
}

.log-time{
    font-size:11px;
}

}

</style>
<video class="video-bg" autoplay muted loop playsinline>
    <source src="/video/background.mp4" type="video/mp4">
</video>

<nav class="navbar">
    <div class="logo">Nitaq</div>
    <div class="nav-links">
        <a href="/dashboard">لوحة التحكم</a>
        <a href="/users">إدارة المستخدمين</a>
    </div>
    <button class="nav-btn" onclick="window.location.href='/logout'">
        تسجيل الخروج
    </button>
</nav>

<section class="dash-container">

    <div class="dash-header">
        <div>
            <h1>سجل التعديلات</h1>
            <p>عرض جميع العمليات الإدارية التي تمت داخل النظام</p>
        </div>
    </div>

    <div class="users-table-wrapper">
        <table class="users-table">
            <thead>
                <tr>
                    <th>الإجراء</th>
                    <th>على الحساب</th>
                    <th>بواسطة</th>
                    <th>الوقت</th>
                </tr>
            </thead>

            <tbody>
                <% if (logs.length === 0) { %>
                    <tr>
                        <td colspan="4" style="text-align:center; opacity:0.6;">
                            لا توجد عمليات مسجلة حالياً
                        </td>
                    </tr>
                <% } %>

                <% logs.slice().reverse().forEach(l => { %>
                <tr>
                    <td>
                        <span class="log-action"><%= l.action %></span>
                    </td>
                    <td><%= l.target %></td>
                    <td><%= l.by %></td>
                    <td class="log-time"><%= l.time %></td>
                </tr>
                <% }) %>
            </tbody>
        </table>
    </div>

</section>

</body>
</html>