<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ملفي الشخصي - Nitaq</title>

    <link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@400;600;700&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/style.css">

    <style>
        /* ===== Layout عام ===== */
        .profile-wrapper{
            min-height:100vh;
            padding:120px 20px;
            display:flex;
            justify-content:center;
            align-items:center;
            position:relative;
            z-index:2;
        }

        .profile-card{
            width:720px;
            background:rgba(255,255,255,0.05);
            backdrop-filter:blur(35px);
            border-radius:35px;
            padding:40px 50px 45px;
            border:1px solid rgba(255,255,255,0.1);
            box-shadow:0 40px 120px rgba(0,0,0,0.7);
            animation:fadeUp .5s ease forwards;
        }

        /* ===== زر الرجوع ===== */
        .back-btn{
            border: none;
            background: rgba(255,255,255,0.06);
            border-radius: 999px;
            padding: 8px 22px;
            color: #f9fafb;
            font-size: 13px;
            cursor: pointer;
            margin-bottom: 16px;
            backdrop-filter: blur(16px);
            border: 1px solid rgba(255,255,255,0.12);
            box-shadow: 0 10px 25px rgba(0,0,0,0.6);
            transition: 0.25s ease;
        }
        .back-btn:hover{
            transform: translateY(-1px);
            background: rgba(255,255,255,0.12);
        }

        /* ===== الهيدر: الاسم + التاق ===== */
        .profile-header{
            margin-bottom:25px;
        }

        .profile-header-top{
            display:flex;
            justify-content:space-between;
            align-items:center;
            gap:16px;
        }

        .profile-name{
            font-size:32px;
            margin:0;
        }

        /* ===== PROFILE ROLE TAG (نفس روح التاقات الفخمة) ===== */
        .profile-role-tag{
            display: inline-block;
            padding: 6px 20px;
            border-radius: 999px;
            font-size: 13px;
            font-weight: 500;
            letter-spacing: 0.5px;
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.12);
            color: #e5e5e5;
            backdrop-filter: blur(14px);
            box-shadow: 0 10px 25px rgba(0,0,0,0.55);
            min-width: 100px;
            text-align: center;
        }

        .profile-role-tag.founder{
            background: radial-gradient(circle at top, rgba(250,204,21,0.25), rgba(24,24,24,0.9));
            border-color: rgba(250,204,21,0.8);
            color: #fde68a;
            box-shadow: 0 0 20px rgba(250,204,21,0.55);
        }

        .profile-role-tag.admin{
            background: radial-gradient(circle at top, rgba(59,130,246,0.25), rgba(24,24,24,0.9));
            border-color: rgba(59,130,246,0.8);
            color: #bfdbfe;
            box-shadow: 0 0 20px rgba(59,130,246,0.45);
        }

        .profile-role-tag.user{
            background: rgba(255,255,255,0.05);
            border-color: rgba(255,255,255,0.18);
            color: #e5e5e5;
        }

        /* ===== رسائل نجاح / خطأ ===== */
        .success-msg{
            background:rgba(34,197,94,0.15);
            padding:10px 14px;
            border-radius:12px;
            margin-bottom:15px;
            border:1px solid rgba(34,197,94,0.4);
            font-size:13px;
        }

        .error-msg{
            background:rgba(239,68,68,0.15);
            padding:10px 14px;
            border-radius:12px;
            margin-bottom:15px;
            border:1px solid rgba(239,68,68,0.4);
            font-size:13px;
        }

        /* ===== معلومات الحساب ===== */
        .profile-info{
            display:grid;
            grid-template-columns:1fr 1fr;
            gap:20px;
            margin:25px 0 35px;
        }

        .info-box{
            background:rgba(255,255,255,0.04);
            padding:18px 20px;
            border-radius:18px;
            border:1px solid rgba(255,255,255,0.08);
        }

        .info-box span{
            display:block;
            font-size:12px;
            opacity:.6;
            margin-bottom:6px;
        }

        .info-box strong{
            font-size:15px;
        }

        /* ===== أقسام التعديل ===== */
        .profile-section{
            margin-top:18px;
        }

        .profile-section h3{
            margin-bottom:10px;
            font-size:16px;
        }

        .profile-section input{
            width:100%;
            padding:13px;
            margin-bottom:12px;
            border-radius:14px;
            border:1px solid rgba(255,255,255,0.1);
            background:rgba(255,255,255,0.05);
            color:white;
            font-family:'IBM Plex Sans Arabic', sans-serif;
        }

        .profile-section button{
            padding:12px 28px;
            border-radius:30px;
            border:none;
            background:white;
            color:black;
            font-weight:600;
            cursor:pointer;
            transition:.3s;
        }

        .profile-section button:hover{
            transform:translateY(-2px);
            box-shadow:0 0 20px rgba(255,255,255,0.6);
        }

        .back-wrapper{
            margin-top:25px;
            text-align:left;
      
      }

      

        @media (max-width: 768px){

/* الكونتينر */
.dash-container{
    padding:120px 16px 50px;
}

/* العنوان */
.dash-header{
    flex-direction:column;
    align-items:flex-start;
    gap:10px;
    margin-bottom:25px;
}

.dash-header h1{
    font-size:26px;
}

/* صندوق البروفايل */
.profile-box{
    padding:20px;
    border-radius:16px;
}

/* الحقول */
.input-group{
    margin-bottom:14px;
}

.input-group label{
    font-size:13px;
}

.input-group input{
    padding:12px;
    font-size:14px;
}

/* زر الحفظ */
.profile-btn,
.nav-btn{
    width:100%;
    padding:14px;
    font-size:14px;
    border-radius:12px;
}

/* الرسائل */
.success-msg,
.error-msg{
    font-size:13px;
    padding:10px;
}

}

        /* ===== Animation ===== */
        @keyframes fadeUp{
            from{opacity:0; transform:translateY(20px);}
            to{opacity:1; transform:translateY(0);}
        }

        @media(max-width:768px){
            .profile-card{
                width:100%;
                padding:28px 22px 30px;
            }
            .profile-info{
                grid-template-columns:1fr;
            }
            .profile-header-top{
                flex-direction:column;
                align-items:flex-start;
            }
        }
    </style>
</head>
<body>

<video class="video-bg" autoplay muted loop playsinline>
    <source src="/video/background.mp4" type="video/mp4">
</video>

<section class="profile-wrapper">
    <div class="profile-card">

        <!-- زر الرجوع -->
        <button class="back-btn" onclick="window.history.back()">
            ← الرجوع
        </button>

        <!-- الاسم + تاق الرتبة على اليمين -->
        <div class="profile-header">
            <div class="profile-header-top">
                <h1 class="profile-name"><%= user.name %></h1>

                <span class="profile-role-tag <%= user.role %>">
                    <% if (user.role === "founder") { %>
                        المؤسس
                    <% } else if (user.role === "admin") { %>
                        أدمن
                    <% } else { %>
                        مستخدم
                    <% } %>
                </span>
            </div>
        </div>

        <!-- رسائل -->
        <% if (success) { %>
            <div class="success-msg"><%= success %></div>
        <% } %>

        <% if (error) { %>
            <div class="error-msg"><%= error %></div>
        <% } %>

        <!-- معلومات الحساب -->
        <div class="profile-info">
            <div class="info-box">
                <span>الاسم</span>
                <strong><%= user.name %></strong>
            </div>

            <div class="info-box">
                <span>البريد</span>
                <strong><%= user.email %></strong>
            </div>

            <div class="info-box">
                <span>تاريخ إنشاء الحساب</span>
                <strong><%= user.createdAt || "غير متوفر" %></strong>
            </div>

            <div class="info-box">
                <span>آخر تسجيل دخول</span>
                <strong><%= user.lastLogin || "لم يسجل دخول بعد" %></strong>
            </div>

            <div class="info-box">
                <span>عدد مرات الدخول</span>
                <strong><%= user.loginCount || 0 %></strong>
            </div>

            <% if (user.role === "admin") { %>
                <div class="info-box">
                    <span>تاريخ الترقية</span>
                    <strong><%= user.promotedAt || "غير مسجل" %></strong>
                </div>
            <% } %>
        </div>

        <!-- تغيير الاسم -->
        <div class="profile-section">
            <h3>تغيير الاسم</h3>
            <form method="POST" action="/profile/change-name">
                <input type="text" name="newName" placeholder="الاسم الجديد" required>
                <button type="submit">حفظ</button>
            </form>
        </div>

        <!-- تغيير كلمة المرور -->
        <div class="profile-section">
            <h3>تغيير كلمة المرور</h3>
            <form method="POST" action="/profile/change-password">
                <input type="password" name="currentPassword" placeholder="كلمة المرور الحالية" required>
                <input type="password" name="newPassword" placeholder="كلمة المرور الجديدة" required>
                <button type="submit">تغيير</button>
            </form>
        </div>

        <!-- رجوع للوحة البداية -->
        <div class="back-wrapper">
            <button class="back-btn" onclick="window.location.href='/home'">
                ← الرجوع للوحة البداية
            </button>
        </div>

    </div>
</section>

</body>
</html>