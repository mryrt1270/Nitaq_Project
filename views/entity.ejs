<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Nitaq</title>

<link href="https://fonts.googleapis.com/css2?family=IBM+Plex+Sans+Arabic:wght@400;600;700&display=swap" rel="stylesheet">
<link rel="stylesheet" href="/style.css">

</head>

<video class="video-bg" autoplay muted loop playsinline>
<source src="/video/background.mp4" type="video/mp4">
</video>

<nav class="navbar">
<div class="logo">Nitaq</div>
<div class="nav-links">
<a href="/services">القطاعات</a>
</div>
<button class="nav-btn" onclick="window.location.href='/logout'">تسجيل الخروج</button>
</nav>

<section class="dash-container">

<div class="dash-header">
<h1><%= entity %></h1>
<p>الصلاحيات النظامية المرتبطة بهذه الجهة</p>
</div>

<div class="users-table-wrapper">

<table class="users-table">
<thead>
<tr>
<th>المستند</th>
<th>الحالة</th>
<th>السبب</th>
<th>المرجع</th>
</tr>
</thead>
<tbody>

<% rules.forEach(function(r){ %>
<tr>

<td><%= r.document %></td>

<td>
<% if(r.allowed){ %>
<span class="status-active">مسموح</span>
<% } else { %>
<span class="status-banned">غير مسموح</span>
<% } %>
</td>

<td><%= r.reason %></td>
<td><%= r.law %></td>

</tr>
<% }) %>

</tbody>
</table>

</div>

</section>

</body>
</html>